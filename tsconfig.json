{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "ignoreDeprecations": "6.0",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["frontend/src/*"]
    },
    "noEmit": true
  },
  "include": [
    "global.d.ts",
    "frontend/src/**/*.ts",
    "frontend/src/**/*.tsx",
    "admin-frontend/src/**/*.ts",
    "admin-frontend/src/**/*.tsx",
    "backend/**/*.ts",
    "backend/**/*.d.ts",
    "frontend/vite.config.ts",
    "admin-frontend/vite.config.ts"
  ],
  "exclude": [
    "backend/models.ts",
    "backend/storage.ts",
    "backend/routes/admin-panel.ts"
  ]
}
