# Local macOS PostgreSQL role. If using docker-compose, use:
# DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/bangla_voice_ai
DATABASE_URL=postgres://mohammadshihan@127.0.0.1:5432/bangla_voice_ai
PORT=5174
FRONTEND_URL=http://127.0.0.1:5173
ADMIN_FRONTEND_URL=http://127.0.0.1:5181
BACKEND_URL=http://127.0.0.1:5174
VOICE_MEDIA_ROOT=backend/media
SOURCE_SQLITE_DB=/Users/mohammadshihan/bangla-speech-ai/db.sqlite3
# Fresh DB verification:
# Pass a disposable DATABASE_URL explicitly when running verify:db:fresh.
# Example:
# DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/bangla_voice_ai_verify npm run verify:db:fresh
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret
CUSTOMER_SESSION_SECRET=replace-with-a-second-long-random-secret
CUSTOMER_SESSION_COOKIE_NAME=bangla_voice_user
# Gmail example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=yourgmail@gmail.com
# SMTP_PASS=your-16-digit-app-password
# SMTP_FROM="Bangla Speech AI <yourgmail@gmail.com>"
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=your-16-digit-app-password
SMTP_FROM="Bangla Speech AI <yourgmail@gmail.com>"
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+15555550123
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_GOLD_PRICE_ID=price_gold_replace_me
STRIPE_PLATINUM_PRICE_ID=price_platinum_replace_me
STRIPE_EXTRA_TOKEN_PRICE_ID=price_extra_tokens_replace_me
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta
BKASH_USERNAME=your-bkash-username
BKASH_PASSWORD=your-bkash-password
BKASH_APP_KEY=your-bkash-app-key
BKASH_APP_SECRET=your-bkash-app-secret
BKASH_CALLBACK_URL=http://127.0.0.1:5174/api/payments/bkash/callback
BKASH_MODE=sandbox
