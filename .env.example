DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/bangla_voice_ai
PORT=5181
VOICE_MEDIA_ROOT=backend/media
PRIVATE_MEDIA_ROOT=backend/private-media

# Leave disabled until the real provider request/response logic is completed in:
# backend/services/voice-provider.ts
VOICE_MODEL_PROVIDER_ENABLED=false
VOICE_MODEL_API_URL=
VOICE_MODEL_API_KEY=
VOICE_MODEL_ID=
VOICE_MODEL_VOICE_ID=

FRONTEND_URL=http://127.0.0.1:5175
ADMIN_FRONTEND_URL=http://127.0.0.1:5175
BACKEND_URL=http://127.0.0.1:5181
# Used only by the public Vite dev server proxy. Defaults to BACKEND_URL.
FRONTEND_BACKEND_URL=http://127.0.0.1:5181

ADMIN_EMAIL=admin@banglaspeechai.local
ADMIN_PASSWORD=change-me-now
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret

CUSTOMER_SESSION_SECRET=replace-with-a-second-long-random-secret
CUSTOMER_SESSION_COOKIE_NAME=bangla_voice_user

# Customer TTS generation. Keep real keys in local .env or deployment env only.
KEYPILLAR_TTS_BASE_URL=https://api.keypillar.org
KEYPILLAR_TTS_ENDPOINT=/v1/voice/generate
KEYPILLAR_TTS_API_URL=
KEYPILLAR_TTS_API_KEY=
KEYPILLAR_TTS_VOICE_ID=keypillar-bd-female
KEYPILLAR_TTS_FORMAT=wav
KEYPILLAR_TTS_PRONUNCIATION_MODE=english_preserve
TTS_CHUNK_MAX_CHARS=1200
FFMPEG_PATH=ffmpeg

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_GOLD_PRICE_ID=
STRIPE_PLATINUM_PRICE_ID=
STRIPE_EXTRA_TOKEN_PRICE_ID=

BKASH_BASE_URL=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_CALLBACK_URL=http://127.0.0.1:5181/api/payments/bkash/callback

# Use a separate disposable database when running:
# npm run verify:db:fresh
